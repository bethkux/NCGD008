  m_TableData:
  - m_Id: 17635459072
    m_Localized: "Hled\xE1m n\u011Bco {0}."
    m_Metadata:
      m_Items: []
  - m_Id: 54956376064
    m_Localized: "Chci n\u011Bco, co je {0} a {1}."
    m_Metadata:
      m_Items: []
  - m_Id: 58253099008
    m_Localized: "Pot\u0159ebuji n\u011Bco {0}, {1} a {2}."
    m_Metadata:
      m_Items: []
  - m_Id: 109624934400
    m_Localized: "Pros\xEDm dejte mi ne\u010Do {0}, {1}, {2} a {3}."
    m_Metadata:
      m_Items: []
  - m_Id: 1309636280320
    m_Localized: Ahoj, alchymisto.
    m_Metadata:
      m_Items: []
  - m_Id: 1077791932416
    m_Localized: "Zdrav\xEDm v\xE1s."
    m_Metadata:
      m_Items: []
  - m_Id: 1416146436096
    m_Localized: "Dobr\xE9 r\xE1no!"
    m_Metadata:
      m_Items: []
  - m_Id: 449626669301760
    m_Localized: Co to je? To nechci. Naschledanou.
    m_Metadata:
      m_Items: []
  - m_Id: 449905288527872
    m_Localized: "Mockr\xE1t d\u011Bkuji!"
    m_Metadata:
      m_Items: []
  - m_Id: 19914063176253440
    m_Localized: "Chci cokoliv! Jenom vyber t\u0159i ingredience a klikni na \"P\u0159ijmout\"!"
    m_Metadata:
      m_Items: []
